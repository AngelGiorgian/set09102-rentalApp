<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateItemPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <HorizontalStackLayout>
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                           FontSize="14"
                           VerticalOptions="Center"
                           HorizontalOptions="StartAndExpand" />
                    <Button Text="×"
                            Command="{Binding ClearErrorCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                            FontSize="18"
                            Padding="5"
                            WidthRequest="30"
                            HeightRequest="30" />
                </HorizontalStackLayout>
            </Border>

            <Entry Placeholder="Title"
                   Text="{Binding TitleText}" />

            <Editor Placeholder="Description"
                    Text="{Binding DescriptionText}"
                    AutoSize="TextChanges"
                    HeightRequest="120" />

            <Entry Placeholder="Daily Rate (e.g. 12.50)"
                   Text="{Binding DailyRateText}"
                   Keyboard="Numeric" />

            <Picker Title="Select Category"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}" />

            <Button Text="Reload Categories"
                    Command="{Binding ReloadCategoriesCommand}" />

            <Entry Placeholder="Latitude (e.g. 55.9533)"
                   Text="{Binding LatitudeText}"
                   Keyboard="Text" />

            <Entry Placeholder="Longitude (e.g. -3.1883)"
                   Text="{Binding LongitudeText}"
                   Keyboard="Text" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Button Text="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>